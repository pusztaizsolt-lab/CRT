<html>
<head>
<meta charset="UTF-8">
<hta:application
    applicationname="CRT Ajanlatseged"
    border="thin"
    caption="yes"
    maximizebutton="no"
    minimizebutton="no"
    showintaskbar="yes"
    singleinstance="yes"
    windowstate="normal"
    scroll="no"
    innerBorder="no"
/>
<title>CRT – Indítás</title>
<style>
    body {
        margin: 0; padding: 0;
        background: #12121f;
        color: #dde1e7;
        font-family: 'Segoe UI', sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100vh;
        text-align: center;
    }
    .box { width: 340px; }
    h1 { font-size: 1.3rem; color: #c8a4f8; margin-bottom: 6px; }
    .ceg { font-size: .75rem; color: #555; margin-bottom: 28px; }
    .step { font-size: .85rem; color: #aaa; margin-bottom: 14px; min-height: 20px; }
    .bar-bg {
        background: #1c1c30;
        border-radius: 4px;
        height: 6px;
        overflow: hidden;
        margin-bottom: 20px;
    }
    .bar-fill {
        height: 100%;
        background: linear-gradient(90deg, #7c5cbf, #00b894);
        border-radius: 4px;
        width: 0%;
    }
    .status { font-size: .72rem; color: #444; }
</style>
</head>
<body>
<div class="box">
    <h1>CRT Ajánlatsegéd</h1>
    <div class="ceg">Civil Rendszertechnika Kft.</div>
    <div class="step" id="step">Előkészítés...</div>
    <div class="bar-bg"><div class="bar-fill" id="bar"></div></div>
    <div class="status" id="status">Kérlek várj...</div>
</div>

<!-- VBScript: csak shell műveletek -->
<script language="VBScript">
Function vbGetBaseDir()
    Dim fso, path
    Set fso = CreateObject("Scripting.FileSystemObject")
    path = window.location.pathname
    If Left(path, 1) = "/" Then path = Mid(path, 2)
    path = Replace(path, "/", "\")
    path = Replace(path, "%20", " ")
    vbGetBaseDir = fso.GetParentFolderName(path)
End Function

Function vbPgRunning(pgCtl, pgData)
    Dim sh
    Set sh = CreateObject("WScript.Shell")
    vbPgRunning = (sh.Run("""" & pgCtl & """ status -D """ & pgData & """", 0, True) = 0)
End Function

Sub vbStartPg(pgCtl, pgData, pgLog)
    Dim sh
    Set sh = CreateObject("WScript.Shell")
    sh.Run """" & pgCtl & """ start -D """ & pgData & """ -l """ & pgLog & """ -w", 0, True
End Sub

Sub vbStartBackend(baseDir)
    Dim sh, cmd
    Set sh = CreateObject("WScript.Shell")
    sh.CurrentDirectory = baseDir
    cmd = "py -3.11 -m uvicorn main:app --host 0.0.0.0 --port 8000"
    sh.Run cmd, 0, False
End Sub

Sub vbOpenBrowser(htmlPath)
    Dim sh
    Set sh = CreateObject("WScript.Shell")
    sh.Run "explorer """ & htmlPath & """", 1, False
End Sub
</script>

<!-- JavaScript: időzítés és sorrend -->
<script language="JavaScript">
var baseDir = vbGetBaseDir();

function setStep(txt, pct) {
    document.getElementById('step').innerText = txt;
    document.getElementById('bar').style.width = pct + '%';
}
function setStatus(txt) {
    document.getElementById('status').innerText = txt;
}

function step1_postgres() {
    setStep('PostgreSQL ellenőrzése...', 10);
    var pgCtl = baseDir + '\\db\\pgsql\\bin\\pg_ctl.exe';
    var pgData = baseDir + '\\db_data';
    var pgLog  = baseDir + '\\pg.log';

    if (!vbPgRunning(pgCtl, pgData)) {
        setStep('PostgreSQL indítása...', 25);
        vbStartPg(pgCtl, pgData, pgLog);
    }
    setStep('PostgreSQL OK', 40);
    setTimeout(step2_backend, 500);
}

function step2_backend() {
    setStep('Backend indítása...', 55);
    vbStartBackend(baseDir);
    setStep('Szerver inicializálása...', 70);
    setStatus('Kérlek várj ~5 másodpercet...');
    setTimeout(step3_open, 5000);
}

function step3_open() {
    setStep('Kezelőpult megnyitása...', 90);
    vbOpenBrowser(baseDir + '\\ui\\kezelőpult.html');
    setTimeout(step4_done, 1500);
}

function step4_done() {
    setStep('Kész! Bezárás...', 100);
    setStatus('A kezelőpult megnyílt a böngészőben.');
    setTimeout(function() { window.close(); }, 1200);
}

window.onload = function() {
    setTimeout(step1_postgres, 300);
};
</script>

</body>
</html>

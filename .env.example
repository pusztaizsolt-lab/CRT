# CRT Ajánlatsegéd – Környezeti változók
# Másold .env névre és töltsd ki éles telepítésnél

# JWT titkosítás – KÖTELEZŐ megváltoztatni!
CRT_JWT_SECRET=crt_dev_secret_CHANGE_IN_PRODUCTION

# Vészkulcs – admin kizárás esetén POST /auth/emergency (min. 16 karakter)
CRT_EMERGENCY_KEY=

# Claude API kulcs (opcionális – beállítható UI-ból is)
ANTHROPIC_API_KEY=sk-ant-...

# Web scraper titkosítás
CRT_ENCRYPT_KEY=

# Környezet
CRT_ENV=production
